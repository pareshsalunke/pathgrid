# Absolute base URL — drives auth callbacks, OG images, sitemap, canonicals.
# Change this one var on domain migration; never hardcode the deployment host.
APP_URL=http://localhost:3000

# SEO indexing: off | on. `off` emits a site-wide noindex (keep off on the
# temporary vercel.app host so Google never indexes it). Flip to `on` at launch.
SEO_INDEXING=off

# Postgres (Neon). Create a DB/branch (EU region), paste the pooled connection
# string, then run `pnpm db:migrate`. Left blank, the app runs fine until a
# DB-backed feature is hit (Phase 1+).
# DATABASE_URL=postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/pathgrid?sslmode=require

# ── Auth.js (Phase 2) ──
# Session/JWT secret. Generate: openssl rand -base64 32
AUTH_SECRET=
# Needed when the host isn't auto-detected (local dev, self-host behind a proxy).
AUTH_TRUST_HOST=true
# GitHub OAuth app → callback: ${APP_URL}/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google OAuth client → redirect URI: ${APP_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Resend magic-link → https://resend.com/api-keys ; EMAIL_FROM must be a verified sender
AUTH_RESEND_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── AI runtime / BYOK (Phase 3) ──
# User provider API keys are NEVER env vars and never touch the server or DB — they
# live in the browser (localStorage) and are forwarded per request (docs/05 §4).
# AI_DISABLED=1 is a kill switch: every /api/ai/* route stops serving. Leave unset to enable.
# AI_DISABLED=
# Comma-separated emails allowed to view /admin/ai (the AI-usage ops table). Anyone
# else — signed in or not — gets a 404. Leave unset to lock the page for everyone.
# ADMIN_EMAILS=you@example.com
