{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/cards/**",
              "components/forms/**",
              "components/glyphs/**",
              "components/navigation/**",
              "components/sections/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|href|disabled|onClick|style|className|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, href, disabled, onClick, style, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|tertiary|magenta)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'tertiary' | 'magenta'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|style|className|key|ref|className|style|children)$/]",
        "message": "<Checkmark> doesn't accept that prop. Declared props: size, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|eyebrow|headline|style|className|children|key|ref|className|style|children)$/]",
        "message": "<ColorBlock> doesn't accept that prop. Declared props: color, eyebrow, headline, style, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorBlock'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:lime|lilac|cream|pink|mint|coral|navy)$/]",
        "message": "<ColorBlock> color must be one of 'lime' | 'lilac' | 'cream' | 'pink' | 'mint' | 'coral' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|background|style|className|children|key|ref|className|style|children)$/]",
        "message": "<FeatureTile> doesn't accept that prop. Declared props: eyebrow, background, style, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|columns|style|className|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: brand, columns, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:inverse|src|label|size|iconSize|onClick|style|className|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: inverse, src, label, size, iconSize, onClick, style, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarqueeStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|style|className|key|ref|className|style|children)$/]",
        "message": "<MarqueeStrip> doesn't accept that prop. Declared props: items, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|className|key|ref|className|style|children)$/]",
        "message": "<PillTabs> doesn't accept that prop. Declared props: options, value, onChange, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|price|period|description|features|cta|ctaVariant|featured|onSelect|style|className|key|ref|className|style|children)$/]",
        "message": "<PricingCard> doesn't accept that prop. Declared props: title, price, period, description, features, cta, ctaVariant, featured, onSelect, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingCard'] > JSXAttribute[name.name='ctaVariant'] > Literal[value!=/^(?:primary|secondary|tertiary|magenta)$/]",
        "message": "<PricingCard> ctaVariant must be one of 'primary' | 'secondary' | 'tertiary' | 'magenta'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromoBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:cta|onCta|style|className|children|key|ref|className|style|children)$/]",
        "message": "<PromoBanner> doesn't accept that prop. Declared props: cta, onCta, style, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TemplateCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|meta|image|previewColor|onClick|style|className|children|key|ref|className|style|children)$/]",
        "message": "<TemplateCard> doesn't accept that prop. Declared props: title, meta, image, previewColor, onClick, style, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|multiline|rows|type|style|className|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: label, placeholder, value, onChange, multiline, rows, type, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|links|activeLink|onNavigate|secondaryCta|primaryCta|onSecondary|onPrimary|sticky|style|className|key|ref|className|style|children)$/]",
        "message": "<TopNav> doesn't accept that prop. Declared props: brand, links, activeLink, onNavigate, secondaryCta, primaryCta, onSecondary, onPrimary, sticky, style, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
